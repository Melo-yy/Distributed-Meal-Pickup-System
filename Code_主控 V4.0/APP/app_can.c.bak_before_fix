/**************************************************************************
Function: app_can_Host_InitSlaveConnections
Input   : none
Output  : none
函数功能：主机端从机连接状态管理初始化。清空连接数并配置每个槽位的超时与重试参�?
入口参数：无
返回  值：�?
**************************************************************************/
void app_can_Host_InitSlaveConnections(void)
{
    connected_slave_count = 0;
    for (int i = 0; i < MAX_SLAVE_COUNT; i++) {
        slave_connections[i].slave_id = 0;
        slave_connections[i].state = HOST_SLAVE_STATE_DISCONNECTED;
        slave_connections[i].retry_count = 0;
        slave_connections[i].last_send_time = 0;
        slave_connections[i].last_confirm_time = 0;
        slave_connections[i].max_retries = 3;
        slave_connections[i].confirm_timeout = 2000;  // 2秒确认超�?
        slave_connections[i].retry_interval = 1000;   // 1秒重试间�?
    }
}

