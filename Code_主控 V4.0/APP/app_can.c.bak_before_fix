/**************************************************************************
Function: app_can_parse_order_data
Input   : data, length, slave_id, order_buf
Output  : bool
函数功能：解析从机发送的订单报文。校验从�?ID 匹配性并将二进制数据转换�?ASCII 字符�?
入口参数：data-原始数据包，
					length-长度�?
					slave_id-预期来源 ID�?
					order_buf-转换后字符串缓冲
返回  值：true-解析成功�?ID 匹配，false-数据长度不足�?ID 不匹�?
**************************************************************************/
static bool app_can_parse_order_data(uint8_t *data, uint8_t length, uint16_t slave_id, uint8_t *order_buf)
{
    if (length < 7 || ((data[1]<< 8) | data[2]) != slave_id) {
				DBG_WARN("从机ID不匹配\r\n");
        return false;
    }
    // 将二进制数据转换为字符串(数据是ASCII字符)
    for (int i = 0; i < 4; i++) {
				// 只处理可视ASCII字符 (32-126) �?x20 ~ 0x7E�?
        if (data[i+3] >= 32 && data[i+3] <= 126) {
            order_buf[i] = (char)data[i+3];
        } else {
            order_buf[i] = '?';
        }
    }
    order_buf[4] = '\0';
    DBG_INFO("收到从机发送的订单:%s\r\n",order_buf);
    return true;
}


