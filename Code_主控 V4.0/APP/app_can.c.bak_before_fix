/**************************************************************************
Function: Find slave connection by slave ID
Input   : slave_id - target slave ID
Output  : pointer to connection, NULL if not found
函数功能：通过从机ID查找连接
入口参数：slave_id - 目标从机ID
返回  值：连接指针，未找到返回NULL
**************************************************************************/
host_slave_connection_t* app_can_Host_FindSlaveConnection(uint16_t slave_id)
{
    for (int i = 0; i < connected_slave_count; i++) {
        if (slave_connections[i].slave_id == slave_id) {
            return &slave_connections[i];
        }
    }
    return NULL;
}

/**************************************************************************
Function: Check if slave ID is in allowed list
Input   : slave_id - slave ID to check
Output  : 1 if allowed, 0 if not allowed
函数功能：检查从机ID是否在允许列表中
入口参数：slave_id - 要检查的从机ID
返回  值：1-允许�?-不允�?
**************************************************************************/
uint8_t app_can_Host_IsSlaveAllowed(uint16_t slave_id)
{
    for (int i = 0; i < Slave_ID_Count; i++) {
        if (Slave_ID_List[i] == slave_id) {
            return 1;  // 在列表中，允许连�?
        }
    }
    return 0;  // 不在列表中，拒绝连接
}

/**************************************************************************
Function: Add new slave connection
Input   : slave_id - new slave ID
Output  : pointer to new connection, NULL if failed
函数功能：添加新的从机连�?
入口参数：slave_id - 新从机ID
返回  值：新连接指针，失败返回NULL
**************************************************************************/
host_slave_connection_t* app_can_Host_AddSlaveConnection(uint16_t slave_id)
{
    if (connected_slave_count >= MAX_SLAVE_COUNT) {
        DBG_ERROR("CAN_HOST: Cannot add slave 0x%03X, max slave count reached\r\n", slave_id);
        return NULL;
    }
    
    // 检查是否已存在
    if (app_can_Host_FindSlaveConnection(slave_id) != NULL) {
        DBG_WARN("CAN_HOST: Slave 0x%03X already exists\r\n", slave_id);
        return NULL;
    }
    
    // 添加到数�?
    host_slave_connection_t* new_conn = &slave_connections[connected_slave_count];
    new_conn->slave_id = slave_id;
    new_conn->state = HOST_SLAVE_STATE_WAITING_CONFIRM;
    new_conn->retry_count = 0;
    new_conn->last_send_time = getSysTickCnt();
    new_conn->last_confirm_time = 0;
    new_conn->max_retries = 3;
    new_conn->confirm_timeout = 2000;
    new_conn->retry_interval = 1000;
    
    connected_slave_count++;
    
    DBG_INFO("CAN_HOST: New slave 0x%03X added, total slaves: %d\r\n", 
           slave_id, connected_slave_count);
    
    return new_conn;
}

/**************************************************************************
Function: Remove slave connection
Input   : slave_id - slave ID to remove
Output  : none
函数功能：移除从机连�?
入口参数：slave_id - 要移除的从机ID
返回  值：�?
**************************************************************************/
void app_can_Host_RemoveSlaveConnection(uint16_t slave_id)
{
	
    for (int i = 0; i < connected_slave_count; i++) {
        if (slave_connections[i].slave_id == slave_id) {
            DBG_INFO("CAN_HOST: Removing slave 0x%03X from connection list\r\n", slave_id);
            
            // 将最后一个元素移动到当前位置
            if (i < connected_slave_count - 1) {
                slave_connections[i] = slave_connections[connected_slave_count - 1];
            }
            
            // 清空最后一个位�?
            slave_connections[connected_slave_count - 1].slave_id = 0;
            slave_connections[connected_slave_count - 1].state = HOST_SLAVE_STATE_DISCONNECTED;
            
            connected_slave_count--;
            return;
        }
    }
}

/**************************************************************************
Function: Host send ping response to slave
Input   : slave_id - target slave ID
Output  : can_status_t status
函数功能：主机向从机发送ping响应
入口参数：slave_id - 目标从机ID
返回  值：can_status_t状�?
**************************************************************************/
can_status_t app_can_Host_SendPingResponse(uint16_t slave_id)
{
    if (!IS_VALID_SLAVE_ID(slave_id)) {
        return CAN_STATUS_INVALID_ID;
    }
    
    // 准备响应数据 [响应类型(1) | 主机ID高字�?1) | 主机ID低字�?1)]
    uint8_t resp_data[3];
    resp_data[0] = RESP_SELF_TEST;
    resp_data[1] = (HOST_ID >> 8) & 0xFF;   // 主机ID高字�?
    resp_data[2] = HOST_ID & 0xFF;          // 主机ID低字�?
    
    // 发送响应到从机
    can_status_t status = bsp_can_Transmit(slave_id, 3, resp_data);
    
    if (status == CAN_STATUS_OK) {
        DBG_INFO("CAN_HOST: Ping response sent to slave 0x%03X\r\n", slave_id);
        
        // 查找或创建连�?
        host_slave_connection_t* conn = app_can_Host_FindSlaveConnection(slave_id);
        if (conn == NULL) {
            conn = app_can_Host_AddSlaveConnection(slave_id);
        }
        
        if (conn != NULL) {
            conn->state = HOST_SLAVE_STATE_WAITING_CONFIRM;
            conn->last_send_time = getSysTickCnt();
            conn->retry_count = 1;  // 第一次发�?
        }
    } else {
        DBG_ERROR("CAN_HOST: Failed to send ping response to slave 0x%03X: %d\r\n", slave_id, status);
    }
    
    return status;
}

/**************************************************************************
Function: Process slave ping request
Input   : recv_id   - received CAN ID
          cmd_data  - command data pointer  
          data_len  - data length
Output  : can_status_t status
函数功能：处理从机ping请求
入口参数：recv_id   - 接收到的CAN ID
          cmd_data  - 命令数据指针
          data_len  - 数据长度
返回  值：can_status_t状�?
**************************************************************************/
can_status_t app_can_Host_ProcessSlavePing(uint32_t recv_id, uint8_t *cmd_data, uint8_t data_len)
{
    // 验证数据长度
    if (data_len < 3) {
        DBG_WARN("CAN_HOST: Slave ping request too short, len=%d\r\n", data_len);
        return CAN_STATUS_RESP_ERROR;
    }
    
    // 解析从机ID
    uint8_t slave_id_high = cmd_data[1];
    uint8_t slave_id_low = cmd_data[2];
    uint16_t slave_id = (slave_id_high << 8) | slave_id_low;
    
    if (!IS_VALID_SLAVE_ID(slave_id) && slave_id == recv_id) {
        DBG_WARN("CAN_HOST: Invalid slave ID 0x%04X from ping request\r\n", slave_id);
        return CAN_STATUS_INVALID_ID;
    }
    
    DBG_INFO("CAN_HOST: Ping request from slave 0x%03X\r\n", slave_id);
    
		// 检查从机是否在从机ID白名单中
    if (!app_can_Host_IsSlaveAllowed(slave_id)) {
        DBG_WARN("CAN_HOST: Slave 0x%03X is not in allowed list, rejecting connection\r\n", slave_id);
        
        // 可选：发送拒绝连接的消息给从�?
        uint8_t reject_data[3];
        reject_data[0] = CMD_REFUSE_PING;  // 拒绝命令�?
        reject_data[1] = (HOST_ID >> 8) & 0xFF;
        reject_data[2] = HOST_ID & 0xFF;
        bsp_can_Transmit(slave_id, 3, reject_data);
        
        return CAN_STATUS_INVALID_ID;
    }
		
    // 发送ping响应
    return app_can_Host_SendPingResponse(slave_id);
}

/**************************************************************************
Function: Process slave ping success confirmation
Input   : slave_id - slave ID that sent confirmation
          cmd_data - command data pointer
          data_len - data length
Output  : can_status_t status
函数功能：处理从机ping成功确认
入口参数：slave_id - 发送确认的从机ID
          cmd_data - 命令数据指针
          data_len - 数据长度
返回  值：can_status_t状�?
**************************************************************************/
can_status_t app_can_Host_ProcessPingSuccess(uint16_t slave_id, uint8_t *cmd_data, uint8_t data_len)
{
    // 验证数据长度
    if (data_len < 3) {
        DBG_WARN("CAN_HOST: Ping success confirmation too short from slave 0x%03X, len=%d\r\n", 
               slave_id, data_len);
        return CAN_STATUS_RESP_ERROR;
    }
    
    // 解析从机ID（确认匹配）
    uint8_t slave_id_high = cmd_data[1];
    uint8_t slave_id_low = cmd_data[2];
    uint16_t received_slave_id = (slave_id_high << 8) | slave_id_low;
    
    if (received_slave_id != slave_id) {
        DBG_ERROR("CAN_HOST: Slave ID mismatch in ping success, expected:0x%03X, got:0x%03X\r\n", 
               slave_id, received_slave_id);
        return CAN_STATUS_INVALID_ID;
    }
    
    // 更新连接状�?
    host_slave_connection_t* conn = app_can_Host_FindSlaveConnection(slave_id);
    if (conn != NULL) {
        conn->state = HOST_SLAVE_STATE_CONNECTED;
        conn->last_confirm_time = getSysTickCnt();
        conn->retry_count = 0;
        
        DBG_INFO("CAN_HOST: Slave 0x%03X confirmed connection successfully\r\n", slave_id);
        
        // 打印当前连接的从机列�?
        DBG_INFO("CAN_HOST: Current connected slaves: ");
        for (int i = 0; i < connected_slave_count; i++) {
            if (slave_connections[i].state == HOST_SLAVE_STATE_CONNECTED) {
                DBG_INFO("0x%03X ", slave_connections[i].slave_id);
            }
        }
        DBG_INFO("\r\n");
    } else {
        DBG_WARN("CAN_HOST: Received ping success from unknown slave 0x%03X\r\n", slave_id);
        return CAN_STATUS_INVALID_ID;
    }
    
    return CAN_STATUS_OK;
}

/**************************************************************************
Function: Host slave connection timeout management
Input   : none
Output  : none
函数功能：主机从机连接超时管�?
入口参数：无
返回  值：�?
**************************************************************************/
void app_can_Host_ConnectionTimeoutManager(void)
{
    uint32_t current_time = getSysTickCnt();
    
    for (int i = 0; i < connected_slave_count; i++) {
        host_slave_connection_t* conn = &slave_connections[i];
        
        if (conn->state == HOST_SLAVE_STATE_WAITING_CONFIRM) {
            // 检查是否超�?
            if (current_time - conn->last_send_time > conn->confirm_timeout) {
                if (conn->retry_count < conn->max_retries) {
                    // 重发ping响应
                    DBG_INFO("CAN_HOST: Confirm timeout for slave 0x%03X, retrying (%d/%d)\r\n", 
                           conn->slave_id, conn->retry_count, conn->max_retries);
                    
                    // 准备响应数据
                    uint8_t resp_data[3];
                    resp_data[0] = RESP_SELF_TEST;
                    resp_data[1] = (HOST_ID >> 8) & 0xFF;
                    resp_data[2] = HOST_ID & 0xFF;
                    
                    // 重发
                    if (bsp_can_Transmit(conn->slave_id, 3, resp_data) == CAN_STATUS_OK) {
                        conn->last_send_time = getSysTickCnt();
                        conn->retry_count++;
                        DBG_INFO("CAN_HOST: Retry ping response sent to slave 0x%03X\r\n", conn->slave_id);
                    } else {
                        DBG_ERROR("CAN_HOST: Retry send failed for slave 0x%03X\r\n", conn->slave_id);
										}
                } else {
                    // 超过最大重试次数，移除连接
                    DBG_WARN("CAN_HOST: Slave 0x%03X connection failed after %d retries, removing\r\n", 
                           conn->slave_id, conn->max_retries);
                    app_can_Host_RemoveSlaveConnection(conn->slave_id);
                    i--; // 因为数组被修改，需要调整索�?
                }
            }
        }
        
        // 对于已连接的从机，可以在这里添加心跳检�?
//        if (conn->state == HOST_SLAVE_STATE_CONNECTED) {
//            // 可选：检查通信超时（比�?0秒无通信�?
//            if (current_time - conn->last_confirm_time > 30000) {
//                printf("CAN_HOST: Slave 0x%03X communication timeout, removing\r\n", conn->slave_id);
//                app_can_Host_RemoveSlaveConnection(conn->slave_id);
//                i--; // 因为数组被修改，需要调整索�?
//            }
//        }
    }
}

/**************************************************************************
Function: Check whether the slave is currently on-line
Input   : slave_id - slave number (1-9)
Output  : 1-on-line, 0-off-line
函数功能：检查从机是否在�?
入口参数：slave_id - 从机编号(1-9)
返回  值：1-在线�?-离线
**************************************************************************/
uint8_t app_can_Host_IsSlaveOnline(uint16_t slave_id)
{
    if (!IS_VALID_SLAVE_ID(slave_id)) return 0;
    
    uint8_t index = slave_id - SLAVE_ID_MIN;
    
    // 检查通信超时�?0秒无通信认为离线�?
    if (xTaskGetTickCount() - slave_status[index].last_comm_time > pdMS_TO_TICKS(10000)) {
        slave_status[index].is_online = 0;
    }
    
    return slave_status[index].is_online;
}

