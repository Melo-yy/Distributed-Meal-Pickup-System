/**************************************************************************
Function: Application CAN host receive handler
Input   : none
Output  : none
函数功能：应用层CAN主机接收处理函数
入口参数：无
返回  值：�?
**************************************************************************/
void app_can_Host_ProcessReceive(void)
{
    if (!bsp_can_ReceiveFlag()) return;

    uint32_t recv_id;
    uint8_t recv_data[8];
    uint8_t recv_len;
		uint8_t order_id[5];

    if (bsp_can_Receive(&recv_id, &recv_len, recv_data)!= CAN_STATUS_OK || recv_len == 0 || recv_len >8 ) return;
	
    // 提取命令码并处理
    if (recv_len > 0) {
        uint8_t cmd = recv_data[0];


    // 处理从机响应	
    if (IS_SLAVE_RESPONSE_ID(recv_id)) {
			// 原数据（0x1001-0x17FF --> 提取从机编号�?01-7FF�?
			uint16_t slave_id = GET_SLAVE_ID_FROM_RESPONSE(recv_id);		
			if (IS_VALID_SLAVE_ID(slave_id)) {
					// 更新从机状�?
					slave_status[slave_id-1].is_online = 1;
					slave_status[slave_id-1].last_comm_time = xTaskGetTickCount();
					
					switch(cmd) {
						
							// 处理从机ping请求
							case CMD_SELF_TEST: 									 
								app_can_Host_ProcessSlavePing(slave_id, recv_data, recv_len);
								break;		
							
								// 处理从机ping成功确认
							case PING_SUCCESS:
								app_can_Host_ProcessPingSuccess(slave_id, recv_data, recv_len);	
								break;
							
							// 对正常通信命令的响�?
							case CMD_TX:  
								if (app_can_parse_order_data(recv_data, recv_len, slave_id, order_id)) {									  
										
										// 不直接处理，而是添加到消息队�?
										uint8_t order_bytes[4];
										memcpy(order_bytes, order_id, 4);
										
										if (app_can_order_AddRequest(slave_id, order_bytes, 0) == pdTRUE) {
												DBG_INFO("HOST: Order request from slave %03X queued, order: %s\r\n", slave_id, order_id);
										} else {
												DBG_WARN("HOST: Failed to queue order request from slave %d\r\n", slave_id);
										}
								}
								break;
								

							// 从机回传的取件成功响�?				
							case CMD_PICK_OK:
								if (recv_len == 5 && ((recv_data[1] << 8) | recv_data[2] )== slave_id) 
								{
                                    // 已经取件的订单编�?
                                    uint8_t pickup_order_id[4] = {0};
                                    uint16_t product_id;
                                    for(int i = 0; i < 4; i++)
                                        pickup_order_id[i] = recv_data[i+3];
                                        // 读取product_id成功 更改取件状�?
                                        if(FlashDB_LoadDeviceProduct(slave_id, &product_id) == 0){
                                            // 更新数据库内订单的取件状态（把pickup_order_id订单更改为已取）
                                            FlashDB_UpdateOrderStatus((const char *)pickup_order_id, product_id, 1);
                                            DBG_INFO("Order-%s has been picked up!\r\n",pickup_order_id);
                                        }else{
                                                DBG_WARN("订单< %s >已被取件，但获取产品ID失败\r\n",pickup_order_id);
                                        }

								}
								break;
								
							default:
								DBG_WARN("HOST: Unknown command 0x%02X from slave %d\r\n", recv_data[0], slave_id);
								break;
					}
				
					DBG_DEBUG("HOST: From slave 0x%03X: ", slave_id);
					for (int i = 0; i < recv_len; i++) {
							DBG_DEBUG("%02X ", recv_data[i]);
					}
					DBG_DEBUG("\r\n");
			}
		}
}
}

