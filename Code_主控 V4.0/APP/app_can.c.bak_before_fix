void can_task(void *pvParameters)
{
    // 等待 FlashDB 和 4G 业务就绪（替代原来 OK_4G_flag 轮询）
    DBG_INFO("CAN任务启动，等待FlashDB就绪...
");
    xEventGroupWaitBits(xStartupEventGroup, BIT_FLASHDB_READY,
    DBG_INFO("CAN任务启动，等待4G业务就绪...
    DBG_INFO("CAN任务启动，等待4G业务就绪...
");
    xEventGroupWaitBits(xStartupEventGroup, BIT_4G_BUSINESS_READY,
    DBG_INFO("can模块就绪，开始CAN通信
    DBG_INFO("can模块就绪，开始CAN通信
");
		
    // CAN初始化（主机�?
    app_can_Host_Init();

    // 在主机启动时4G模块收到数据后调用
    uint16_t allowed_slaves[] = {0};
		DBG_INFO("从机列表:");
		//从4G模块读取装置列表
		uint8_t allowed_cnt = DeviceMgr_Export(allowed_slaves,MAX_SLAVE_COUNT);
		for(int i = 0; i < allowed_cnt; i++)
			DBG_INFO("%03x ",allowed_slaves[i]);
		DBG_INFO("\n");
    app_can_Host_InitSlaveIDList(allowed_slaves, allowed_cnt);

	  u32 lastWakeTime = getSysTickCnt();
		
		
		// 接受订单处理消息队列
		order_request_t current_request;
    uint8_t order_id_str[5] = {0};
		
    // 接受扫码消息队列结构�?
    scan_event_t can_event;

    while(1)
    {
    	vTaskDelayUntil(&lastWakeTime, F2T(RATE_10_HZ)); //10ms执行一�?	
			
			/* 处理can接收 */
			app_can_Host_ProcessReceive();
			
			// 处理CAN队列中的扫码事件
			if (xCanQueue != NULL) {
					if (xQueueReceive(xCanQueue, &can_event, 0) == pdTRUE) {
							if (can_event.data_ready  && can_event.is_valid_order ) {
								// 主机将本身扫描器得到的订单id加入消息队列
								app_can_process_host_scan_order(can_event.qr_data);
							}
					}
			}
			
		// 处理连接超时管理（每100ms检查一次）
       static uint32_t last_conn_check = 0;
       if (getSysTickCnt() - last_conn_check > 100) {
					app_can_Host_ConnectionTimeoutManager();
					last_conn_check = getSysTickCnt();
       }
			 
		// 检查主机订单处理超时（100ms检查一次）
        static uint32_t last_timeout_check = 0;
        if (getSysTickCnt() - last_timeout_check > 100) {
            app_can_Host_CheckOrderTimeout();
            last_timeout_check = getSysTickCnt();
        }
			
        // 等待订单请求（非阻塞方式�?
        if (xQueueReceive(xOrderRequestQueue, &current_request, 0) == pdTRUE) {
            // 处理当前请求(后续不使用order_id_str 这个数组输出会一乱码)
            memcpy(order_id_str, current_request.order_id, 4);
            order_id_str[4] = '\0';
            
            uint32_t wait_time = getSysTickCnt() - current_request.timestamp;
            DBG_INFO("ORDER_TASK: Processing request - device:0x%03X, order:%s, waited:%lums, queue:%lu\r\n", 
                            current_request.device_id,  order_id_str, wait_time, 
                            uxQueueMessagesWaiting(xOrderRequestQueue));
            
            // 根据设备类型处理请求
            if (current_request.device_id == HOST_ID) {
                    // 主机扫码订单
                    app_can_process_host_order_request(current_request.device_id, order_id_str);
            } else {
                    // 从机订单请求
                    app_can_process_slave_order_request(current_request.device_id, order_id_str);
            }
        }
			
		}
}		