/**************************************************************************
Function: 开始主机订单处理计�?
Input   : order_id - 订单ID
Output  : �?
函数功能：开始主机订单处理计�?
入口参数：order_id - 订单ID
返回  值：�?
**************************************************************************/
void app_can_Host_StartOrderProcessing(uint8_t *order_id)
{
    host_order_proc.is_processing = 1;
    memcpy(host_order_proc.order_id, order_id, 4);
    host_order_proc.start_time = getSysTickCnt();
    host_order_proc.timeout_checked = 0;
    
    DBG_INFO("HOST_ORDER: Started processing order %.4s at time %lu\r\n", 
           order_id, host_order_proc.start_time);
}

/**************************************************************************
Function: 结束主机订单处理
Input   : �?
Output  : �?
函数功能：结束主机订单处�?
入口参数：无
返回  值：�?
**************************************************************************/
void app_can_Host_EndOrderProcessing(void)
{
    if (host_order_proc.is_processing) {
        uint32_t process_time = getSysTickCnt() - host_order_proc.start_time;
        DBG_INFO("HOST_ORDER: Finished processing order %.4s, took %lu ms\r\n", 
               host_order_proc.order_id, process_time);
    }
    
    host_order_proc.is_processing = 0;
    memset(host_order_proc.order_id, 0, sizeof(host_order_proc.order_id));
    host_order_proc.start_time = 0;
    host_order_proc.timeout_checked = 0;
}


/**************************************************************************
Function: 检查主机订单处理超�?
Input   : �?
Output  : �?
函数功能：检查主机订单处理是否超�?
入口参数：无
返回  值：�?
**************************************************************************/
void app_can_Host_CheckOrderTimeout(void)
{
    if (!host_order_proc.is_processing || host_order_proc.timeout_checked) {
        return;
    }
    
    uint32_t current_time = getSysTickCnt();
    uint32_t elapsed_time = current_time - host_order_proc.start_time;
    
    if (elapsed_time > HOST_ORDER_PROCESS_TIMEOUT) {
        DBG_ERROR("HOST_ORDER: Timeout! Order %.4s processing took %lu ms (> %d ms)\r\n", 
               host_order_proc.order_id, elapsed_time, HOST_ORDER_PROCESS_TIMEOUT);
        
        // 生成超时事件
        Host_response_event_t timeout_event;
        timeout_event.Host_id = HOST_ID;
        memcpy(timeout_event.order_id, host_order_proc.order_id, 4);
        timeout_event.event_type = ORDER_EVENT_TIMEOUT;
        timeout_event.channel_num = 0;
        timeout_event.quantity = 0;
        
        // 发送到语音队列
        if (xHostVoiceQueue != NULL) {
            if (xQueueSend(xHostVoiceQueue, &timeout_event, 0) == pdTRUE) {
                DBG_INFO("HOST_QUEUE: Timeout event sent to voice queue, order: %.4s\r\n", 
                       host_order_proc.order_id);
            } else {
                DBG_WARN("HOST_QUEUE: Voice queue full, timeout event dropped\r\n");
            }
        }
        
        // 发送到显示队列
        if (xHostDisplayQueue != NULL) {
            if (xQueueSend(xHostDisplayQueue, &timeout_event, 0) == pdTRUE) {
                DBG_INFO("HOST_QUEUE: Timeout event sent to display queue, order: %.4s\r\n", 
                       host_order_proc.order_id);
            } else {
                DBG_WARN("HOST_QUEUE: Display queue full, timeout event dropped\r\n");
            }
        }
        
        
        // 结束处理
        app_can_Host_EndOrderProcessing();
    }
}

/**************************************************************************
Function: Send order acknowledgment to slave
Input   : slave_id - target slave ID
          order_id - order ID bytes
Output  : can_status_t status
函数功能：向从机发送订单确�?
入口参数：slave_id - 目标从机ID
          order_id - 订单ID字节
返回  值：can_status_t状�?
**************************************************************************/
can_status_t app_can_Host_SendOrderAck(uint16_t slave_id, uint8_t *order_id)
{
    if (!IS_VALID_SLAVE_ID(slave_id)) {
        return CAN_STATUS_INVALID_ID;
    }
    
    // 准备确认数据 [命令�?1) | 从机ID(1) | 订单ID(4)]
    uint8_t ack_data[7];
    ack_data[0] = CMD_ORDER_ACK;  // 订单确认命令�?
    ack_data[1] = (slave_id >> 8) & 0xFF;       // 从机ID高字�? 
    ack_data[2] = slave_id & 0xFF;							// 低字�?
    ack_data[3] = order_id[0];    // 订单ID字节1
    ack_data[4] = order_id[1];    // 订单ID字节2
    ack_data[5] = order_id[2];    // 订单ID字节3
    ack_data[6] = order_id[3];    // 订单ID字节4
    
    // 发送到从机
    can_status_t status = bsp_can_Transmit(slave_id, 7, ack_data);
    
		DBG_DEBUG("DEBUG_HOST: Sending to slave 0x%03X, data: ", slave_id);
    for(int i = 0; i < 7; i++) {
        DBG_DEBUG("%02X ", ack_data[i]);
    }
    DBG_DEBUG("\r\n");
		
    if (status == CAN_STATUS_OK) {
        DBG_INFO("CAN_HOST: Order ACK sent to slave 0x%03X\r\n", slave_id);
    } else {
        DBG_ERROR("CAN_HOST: Failed to send order ACK to slave 0x%03X: %d\r\n", slave_id, status);
    }
    
    return status;
}


/**************************************************************************
Function: Add order request to queue
Input   : device_id - device ID (host or slave)
          order_id  - order ID (4 bytes)
          request_type - 0: slave request, 1: host scan
Output  : pdTRUE if success, pdFALSE if failed
函数功能：添加订单请求到队列
入口参数：device_id - 装置ID
          order_id - 订单ID
          request_type - 请求类型
返回  值：pdTRUE-成功，pdFALSE-失败
**************************************************************************/
BaseType_t app_can_order_AddRequest(uint16_t device_id, uint8_t *order_id, uint8_t request_type)
{
    if (xOrderRequestQueue == NULL) {
        DBG_ERROR("ORDER_QUEUE: Queue not initialized\r\n");
        return pdFALSE;
    }
    
    order_request_t new_request;
    new_request.device_id = device_id;
    memcpy(new_request.order_id, order_id, 4);
    new_request.timestamp = getSysTickCnt();
    new_request.request_type = request_type;
    
    // 尝试添加请求到队列（非阻塞方式）
    BaseType_t result = xQueueSend(xOrderRequestQueue, &new_request, 0);
    
    if (result == pdTRUE) {
        UBaseType_t queue_count = uxQueueMessagesWaiting(xOrderRequestQueue);
        DBG_INFO("ORDER_QUEUE: Request added, device:0x%03X, order:%.4s, queue:%lu/%d\r\n", 
               device_id, order_id, queue_count, ORDER_QUEUE_LENGTH);
				// 如果是从机请求，立即发送主机确认收到信息命�?
				if (request_type == 0 && IS_VALID_SLAVE_ID(device_id)) {
						app_can_Host_SendOrderAck(device_id, order_id);
				}
    } else {
        DBG_WARN("ORDER_QUEUE: Queue full! Cannot add request from device:0x%03X\r\n", device_id);
    }
    
    return result;
}


/**************************************************************************
Function: 主机直接处理扫码订单（无CAN传输�?
Input   : order_id - 扫码得到的订单ID
Output  : �?
说明     : 直接从FlashDB查询订单信息，生成事件通知语音和显示模�?
**************************************************************************/
void app_can_process_host_order_request(uint8_t host_id, uint8_t *order_id)
{
    DBG_INFO("HOST_SCAN: Processing order %s directly from scan module\r\n", order_id);
    
		// 检查是否与当前处理的订单匹�?
    if (host_order_proc.is_processing && memcmp(host_order_proc.order_id, order_id, 4) == 0) {
        DBG_INFO("HOST_SCAN: Order %.4s is being processed, timeout check reset\r\n", order_id);
    }
	
    // 初始化订单事件结构体
    Host_response_event_t order_event;
    uint16_t product_id; //产品ID
    order_event.Host_id = host_id;           // 主机ID固定�?
		memcpy(order_event.order_id, order_id, 4);
	
    // 在FlashDB中查询订单信息（查询order_id�?
    order_t order = {0};

    // 根据主控装置ID-->查询商品ID是否为空
    if(FlashDB_LoadDeviceProduct(host_id, &product_id) == 0){
        /**  ===== �?FlashDB 读取订单信息 =====  **/
        if (FlashDB_LoadOrder((const char *)order_id, product_id, &order) == 0) {
            // 订单存在-->判断是否已被取件
            if(order.status == 0){
                // 订单存在且未取件 --> 自动标记为已取件
                order_event.event_type = ORDER_EVENT_VALID;
                order_event.channel_num = order.product_id;   // 假设产品id为通道编号
                order_event.quantity = order.quantity;
                DBG_INFO("HOST_SCAN: Found order %s, qty=%d, status=%d\r\n",
                    order.order_id, order.quantity, order.status);

                // 更新FlashDB中的订单状�?由于是本机订单，无需等待回传，收到正确的订单ID认为已成功取�?
                FlashDB_UpdateOrderStatus((const char *)order_id, product_id, 1);
                DBG_INFO("HOST_SCAN: Order %s automatically marked as picked up\r\n", order_id);
            }else{
                // 订单存在但已取件 --> 修改状态退�?
                order_event.event_type = ORDER_EVENT_ALREADY_PICKED;
                DBG_INFO("HOST_SCAN: Order %s already picked\r\n", order_id);
            }   
        } else {
            // 查询无此订单 --> 修改状态为订单无效
            order_event.event_type = ORDER_EVENT_INVALID;
            DBG_INFO("HOST_SCAN: Order %s is invalid\r\n", order_id);
        }
    }else{
        // 查询商品ID为空 --> 装置未分配商品通道
        order_event.event_type = ORDER_EVENT_DEVICE_NO_CHANNEL;
        DBG_WARN("Host Device(%03X) not set channle!\r\n",host_id);
    }

	// 发送到主机语音队列
    if (xHostVoiceQueue != NULL) {
        if (xQueueSend(xHostVoiceQueue, &order_event, 0) == pdTRUE) {
            DBG_INFO("HOST_QUEUE: Event sent to voice queue, type: %d, order: %s\r\n", 
                   order_event.event_type, order_event.order_id);
        } else {
            DBG_WARN("HOST_QUEUE: Voice queue full, event dropped\r\n");
        }
    }
    
    // 发送到主机显示队列
    if (xHostDisplayQueue != NULL) {
        if (xQueueSend(xHostDisplayQueue, &order_event, 0) == pdTRUE) {
            DBG_INFO("HOST_QUEUE: Event sent to display queue, type: %d, order: %s\r\n", 
                   order_event.event_type, order_event.order_id);
        } else {
            DBG_WARN("HOST_QUEUE: Display queue full, event dropped\r\n");
        }
    }
		
	// 处理完成，结束计�?
    app_can_Host_EndOrderProcessing();
    
    DBG_INFO("HOST_SCAN: Order %s processing completed, event type: %d\r\n", 
           order_id, order_event.event_type);
}


/**************************************************************************
Function: app_can_process_slave_order_request
Input   : slave_id, order_id
Output  : none
函数功能：处理从机订单查询请求。校验订单是否存在、是否已取、所属通道及数量，并回�?CAN 响应
入口参数：slave_id-来源从机 ID�?
					order_id-指向待校验订单字符串的指�?
返回  值：�?
**************************************************************************/
static void app_can_process_slave_order_request(uint16_t slave_id, uint8_t *order_id)
{
    DBG_INFO("CAN_PROC: Order request from slave %03X, order:%s\r\n", slave_id, order_id);

    //订单是否存在、订单状态（�?未取）、通道编号、餐品数�?
    uint8_t order_exists = 0;
    uint8_t	order_status = 0;
    uint8_t response_channel = 0;
    uint8_t quantity = 0;

    uint16_t slave_product_id; //产品ID
    // 在FlashDB中查询订单信息（查询order_id�?
    order_t order;
    // 查询装置对应的商品ID
    if(FlashDB_LoadDeviceProduct(slave_id, &slave_product_id) == 0){
        // 订单ID + 商品ID 查询订单
        if (FlashDB_LoadOrder((const char *)order_id, slave_product_id, &order) == 0) {
            order_status = order.status;
            quantity = order.quantity;
            response_channel = order.product_id; //暂定通道编号为产品id
            order_exists = 1; //订单存在
					  FlashDB_UpdateOrderStatus((const char *)order_id,slave_product_id,1);
        }else{
            // 订单无效或者取件通道错误，核对取件地点、时间、通道�?
            /*************************************************/
            order_exists = 0;
            order_status = 0;
            response_channel = 0;
            quantity = 0;
        }
        if (!order_status) {
            DBG_INFO("CAN_PROC: From Slave: %03X\r\n Order %s found, channel: %d, quantity: %d, marked as picked up.\r\n", 
                                slave_id, order_id, response_channel, quantity);
        }else{
                DBG_INFO("Sorry! This order(%s) has been picked!\r\n", order_id);
        }					
    }else{
        // 该从机装置未分配商品通道
        order_exists = 0; 
        order_status = 0;
        quantity = 0;
        response_channel = CHANNEL_INVALID;
        DBG_WARN("CAN_PROC: Slave: %03X not set channle!\r\n", slave_id);
    }
    
    // 直接构建响应数据并发�?
    uint8_t response_data[8] = {0};
    
    response_data[0] = (slave_id >> 8) & 0xFF;     // 目标从机ID 高字�?
		response_data[1] = slave_id & 0xFF;			   		 // 低字�?
    response_data[2] = order_exists;               // 订单是否存在
    response_data[3] = response_channel;           // 通道编号
    response_data[4] = order_status;               // 取件状�?
    response_data[5] = quantity;                   // 数量
    
    if (app_can_Host_SendCmd(slave_id, RESP_TX, response_data, 6) == CAN_STATUS_OK) {
        DBG_INFO("CAN_SEND: Order response sent to slave %03X, order: %s, exists: %d\r\n", 
               slave_id, order_id, order_exists);
    } else {
        DBG_ERROR("CAN_SEND: Failed to send order response to slave %d\r\n", slave_id);
    }
}


