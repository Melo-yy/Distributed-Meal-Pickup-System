/**************************************************************************
Function: Send command to slave and refresh activity timestamp
Input   : slave_id - target slave ID (1-9)
          cmd      - command byte
          data     - pointer to parameter bytes (NULL if none)
          data_len - number of parameter bytes (0-7)
Output  : can_status_t - operation result
函数功能：向从机发送命令，并在发送成功后更新最后通信时间�?
入口参数：slave_id - 目标从机编号(1-9)
          cmd      - 命令�?
          data     - 参数数据指针（无参数时填NULL�?
          data_len - 参数长度�?-7�?
返回  值：can_status_t 枚举�?
          CAN_STATUS_OK        发送成功且时间戳已更新
          CAN_STATUS_INVALID_ID 从机编号非法
          CAN_STATUS_RESP_ERROR 参数长度>7或data为空但data_len>0
          其余�?              来自bsp_can_Transmit的底层错�?
**************************************************************************/
can_status_t app_can_Host_SendCmd(uint16_t slave_id, uint8_t cmd, uint8_t *data, uint8_t data_len)
{
    // 参数验证
    if (!IS_VALID_SLAVE_ID(slave_id)) {
        return CAN_STATUS_INVALID_ID;
    }
    if (data_len > 7 || (data_len > 0 && data == NULL) ) {
        return CAN_STATUS_RESP_ERROR;
    }

    // 构建发送数�?
    uint8_t tx[8] = {cmd}; 		//�?0 字节固定�?命令�?
    if (data_len > 0) {
        memcpy(&tx[1], data, data_len);
    }

    // 发送并更新状�? （发送的11位标准CAN标识符StdId与接受端的ID一致，接收端置监听与本身ID一致的信息，实现指定端发送）
    can_status_t st = bsp_can_Transmit(slave_id, data_len + 1, tx);
		
    if (st == CAN_STATUS_OK) {
        slave_status[slave_id - SLAVE_ID_MIN].last_comm_time = getSysTickCnt();
    }
    return st;
}


